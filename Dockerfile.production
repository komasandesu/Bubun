FROM node:22-alpine

WORKDIR /app

# ビルドに必要なツールをインストール
RUN apk add --no-cache python3 make g++

# package.json と yarn.lock をコピー
COPY package.json yarn.lock ./

# 依存関係をインストール
RUN yarn install

# ソースコードをコピー
COPY . .

# Prismaの生成
RUN npx prisma generate

# アプリケーションをビルド
RUN yarn build

# 本番用の依存関係のみを再インストール
RUN yarn install --production

EXPOSE 3000

# 起動コマンドを修正
CMD ["node", "build/server/index.js"]